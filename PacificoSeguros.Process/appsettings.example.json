{
  "ConnectionStrings": {
    "AppConnection": "<connection-string>"
  },
  "OracleApi": {
    "BaseUrl": "<oracle-api-base-url>",
    "IniLlamadaPath": "<path-ini-llamada>",
    "FinLlamadaPath": "<path-fin-llamada>",
    "SubscriptionKey": "<subscription-key>",
    "Resource": "<oracle-resource-identifier>",
    "TokenPath": "<path-token>",
    "TokenSubscriptionKey": "<token-subscription-key>",
    "ClientCredential": "<client-credential>",
    "ReprocessDate": "",
    "PollingIntervalSeconds": 30,
    "MaxConcurrentWorkers": 5,
    "TokenLockTimeoutSeconds": 30,
    "RateLimitPerMinute": 100,
    "BatchSize": 20,
    "ClaimTimeoutMinutes": 20
  },
  "Watchdog": {
    "StaleMultiplier": 6,
    "MinStaleThresholdSeconds": 300,
    "MaxNoProgressMinutes": 15
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File", "Serilog.Sinks.MSSqlServer", "Serilog.Expressions" ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "MSSqlServer",
        "Args": {
          "restrictedToMinimumLevel": "Warning",
          "connectionString": "<connection-string-logs>",
          "sinkOptionsSection": {
            "tableName": "<nombre-tabla-logs>",
            "autoCreateSqlTable": true
          }
        }
      },
      {
        "Name": "Logger",
        "Args": {
          "configureLogger": {
            "Filter": [
              {
                "Name": "ByIncludingOnly",
                "Args": { "expression": "@l in ['Debug', 'Information']" }
              }
            ],
            "WriteTo": [
              {
                "Name": "File",
                "Args": {
                  "path": "Logs\\log-.txt",
                  "rollingInterval": "Day",
                  "retainedFileCountLimit": 30
                }
              }
            ]
          }
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  }
}
