{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "AppConnection": "Data Source=<SERVER>;Initial Catalog=<DATABASE>;Persist Security Info=True;User ID=<USER>;Password=<PASSWORD>;TrustServerCertificate=True"
  },
  "OracleApi": {
    "BaseUrl": "https://<APIM_HOST>",
    "TokenPath": "/pga-tokens/soporte-ti/v2/tokens",
    "IniLlamadaPath": "/oi-solicita-url-crm-gen/soporte-ti/v1/CTI_Interaccion_c",
    "FinLlamadaPath": "/oi-finaliza-llamada-crm-gen/soporte-ti/v1/CTI_Interaccion_c",
    "TokenSubscriptionKey": "<TOKEN_SUBSCRIPTION_KEY>",
    "ClientCredential": "<CLIENT_CREDENTIAL_BASE64>",
    "Resource": "<AZURE_RESOURCE_ID>",
    "SubscriptionKey": "<SUBSCRIPTION_KEY>",
    "PollingIntervalSeconds": 10,
    "MaxConcurrentWorkers": 5
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.MSSqlServer" ],
    "MinimumLevel": "Warning",
    "WriteTo": [
      {
        "Name": "MSSqlServer",
        "Args": {
          "connectionString": "Data Source=<SERVER>;Initial Catalog=<DATABASE>;Persist Security Info=True;User ID=<USER>;Password=<PASSWORD>;TrustServerCertificate=True",
          "tableName": "GSS_LogPacifico",
          "autoCreateSqlTable": true,
          "batchPostingLimit": 50,
          "period": "00:00:10",
          "columnOptionsSection": {
            "addStandardColumns": [ "LogEvent" ],
            "removeStandardColumns": [ "Properties" ],
            "additionalColumns": [
              { "ColumnName": "MachineName", "DataType": "nvarchar", "DataLength": 50 },
              { "ColumnName": "Application", "DataType": "nvarchar", "DataLength": 100 },
              { "ColumnName": "Celular", "DataType": "nvarchar", "DataLength": 160 },
              { "ColumnName": "ContactId", "DataType": "nvarchar", "DataLength": 200 }
            ]
          }
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithEnvironmentUserName" ]
  }
}
